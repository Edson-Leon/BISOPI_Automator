# Configuración de BISOPI Automator
# Copia este archivo como .env y completa los valores reales.
# NUNCA subas el .env al repositorio.

EMAIL_COLABORADOR=edson.leon@bisionconsulting.com
BISOPI_API_TOKEN=

# Opcional: ruta completa al archivo de plantilla.
# Si se configura, la app lee y escribe directamente sin necesidad de cargar ni descargar.
# Ejemplo Windows: C:/Users/Edson/bisopi/Plantilla_BISOPI_Automator.xlsx
PLANTILLA_PATH=C:/BISOPI_Automator/data/Plantilla_BISOPI_Automator.xlsx

# Ambiente de ejecución: 'local' o 'cloud'
# En Streamlit Cloud configurar como 'cloud'
# En local dejar vacío o configurar como 'local'
BISOPI_ENV=local

# ── Submodo B: Microsoft Graph API ─────────────────────────────────────────────
# Requiere que IT registre la aplicación en Azure AD y entregue los valores.
# Deja estos campos vacíos si aún no tienes las credenciales.
# Una vez configurados, aparece el botón "Conectar con Microsoft" en la pestaña Outlook.
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
