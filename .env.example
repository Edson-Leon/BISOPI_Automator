# ============================================
# BISOPI Automator — Configuracion local
# Copia este archivo a .env y completa los valores
# ============================================

# Email corporativo del usuario en BISOPI (requerido en local)
EMAIL_COLABORADOR=

# Token de autenticacion de la API de BISOPI
# Solicitar a Carlos Manrique
BISOPI_API_TOKEN=

# Ruta completa al archivo Excel de plantilla (opcional)
# Si se configura, la app lee y escribe directamente sin cargar ni descargar
# Ejemplo Windows: C:/Users/TuUsuario/bisopi/Plantilla_BISOPI_Automator.xlsx
PLANTILLA_PATH=

# Credenciales de Microsoft Azure AD (opcional)
# Requerido solo para integracion con calendario de Outlook via Graph API
# Solicitar AZURE_CLIENT_ID a IT una vez registrada la app en Azure AD
AZURE_CLIENT_ID=
AZURE_TENANT_ID=

# Ambiente de ejecucion: 'local' o 'cloud'
# Dejar como 'local' para uso en tu ordenador
# En Streamlit Cloud configurar como 'cloud'
BISOPI_ENV=local
